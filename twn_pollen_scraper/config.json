{
  "name": "Weather Network Pollen Scraper",
  "version": "0.1.0",
  "slug": "twn_pollen_scraper",
  "description": "Scrapes pollen levels, allergens, and 3‑day forecast from The Weather Network using Browserless + Pyppeteer.",
  "arch": [
    "aarch64",
    "amd64"
  ],
  "startup": "application",
  "boot": "auto",
  "init": false,
  "map": [
    "share:rw"
  ],
  "options": {
    "pollen_url": "https://www.theweathernetwork.com/en/city/ca/ontario/ottawa/pollen",
    "scrapes_per_day": 2,
    "browserless_url": "ws://homeassistant:3000",
    "debug_mode": false
  },
  "schema": {
    "pollen_url": "str",
    "scrapes_per_day": "int",
    "browserless_url": "str",
    "debug_mode": "bool"
  },
  "image": "local/twn_pollen_scraper"
}
