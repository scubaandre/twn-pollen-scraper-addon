{
  "name": "Weather Network Pollen Scraper",
  "version": "0.2.3",
  "slug": "twn_pollen_scraper",
  "description": "Scrapes pollen levels, allergens, and 3‑day forecast from The Weather Network using Browserless + Pyppeteer, publishes to MQTT with auto-discovery.",
  "arch": [
    "aarch64",
    "amd64"
  ],
  "startup": "application",
  "boot": "auto",
  "init": false,
  "map": [
    "share:rw"
  ],
  "options": {
    "pollen_url": "https://www.theweathernetwork.com/en/city/ca/ontario/ottawa/pollen",
    "scrapes_per_day": 2,
    "browserless_url": "ws://homeassistant:3000",
    "debug_mode": false,

    "mqtt_host": "homeassistant",
    "mqtt_port": 1883,
    "mqtt_username": "",
    "mqtt_password": "",
    "mqtt_base_topic": "home/pollen"
  },
  "schema": {
    "pollen_url": "str",
    "scrapes_per_day": "int",
    "browserless_url": "str",
    "debug_mode": "bool",

    "mqtt_host": "str",
    "mqtt_port": "int",
    "mqtt_username": "str?",
    "mqtt_password": "str?",
    "mqtt_base_topic": "str"
  },
  "image": "local/twn_pollen_scraper"
}
